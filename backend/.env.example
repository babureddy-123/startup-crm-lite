# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
# Replace with your actual MongoDB Atlas connection string URL
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/crm_lite?retryWrites=true&w=majority

# Security credentials
# Replace with a strong, random hash string for JWT signatures
JWT_SECRET=your_jwt_secret_hash_phrase_here

# Client permissions configuration
FRONTEND_URL=http://localhost:5173
